@inject Microsoft.AspNetCore.Identity.UserManager<TECHHUB.Models.ApplicationUser> UserManager
@{
    var currentUser = User.Identity?.IsAuthenticated == true ? await UserManager.GetUserAsync(User) : null;
    var fullName = currentUser?.FullName ?? "System Admin";
    var email = currentUser?.Email ?? "";
    var initials = "IT";
    if (currentUser != null && !string.IsNullOrWhiteSpace(currentUser.FullName))
    {
        var parts = currentUser.FullName.Split(' ', StringSplitOptions.RemoveEmptyEntries);
        if (parts.Length > 1)
        {
            initials = (parts[0][0].ToString() + parts[1][0].ToString()).ToUpper();
        }
        else if (parts.Length > 0)
        {
            initials = parts[0][0].ToString().ToUpper();
        }
    }
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no" />
    <link rel="icon" type="image/png" href="~/favicon.png" />
    <title>@ViewData["Title"] - IT Asset Management & HelpDesk</title>

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/simple-datatables@7.1.2/dist/style.min.css" rel="stylesheet" />
    <link href="~/techhub-template/assets/css/theme.css" rel="stylesheet" />
    <link href="~/css/additionaldesigncomponents.css" rel="stylesheet" />
</head>
<body class="app-shell">

    <nav class="app-topnav">
        <button class="sidenav-toggle" id="sidenavToggle" type="button" aria-label="Toggle sidebar">
            <i class="fas fa-bars"></i>
        </button>

        <a class="app-brand" asp-controller="Default" asp-action="Index">
            <span class="brand-mark"><i class="fab fa-hive"></i></span>
            <span>TECHHUB</span>
        </a>

        <div class="topnav-actions">
            @if (User.Identity?.IsAuthenticated == true)
            {
                <div class="dropdown">
                    <a class="topnav-profile" href="#" role="button" data-bs-toggle="dropdown">
                        <span class="avatar">@initials</span>
                        <span class="d-none d-lg-block">
                            <span class="profile-name d-block">@fullName</span>
                            <span class="profile-role d-block text-truncate" style="max-width: 140px; font-size: 0.75rem; opacity: 0.85;">@email</span>
                        </span>
                        <i class="fas fa-chevron-down d-none d-lg-inline" style="font-size: 0.7rem; color: var(--slate-400);"></i>
                    </a>
                    <ul class="dropdown-menu dropdown-menu-end dropdown-menu-dark-soft">
                        <li><a class="dropdown-item" asp-controller="Account" asp-action="AccountDetails"><i class="fas fa-user me-2"></i>Account Details</a></li>
                        <li><a class="dropdown-item" asp-controller="Account" asp-action="ManageChangePassword"><i class="fas fa-key me-2"></i>Change Password</a></li>
                        <li><hr class="dropdown-divider" /></li>
                        <li><a class="dropdown-item text-danger-hover" href="javascript:void(0);" onclick="submitLogoutForm();"><i class="fas fa-right-from-bracket me-2"></i>Sign out</a></li>
                    </ul>
                </div>
            }
            else
            {
                <a class="btn btn-sm btn-outline-light" asp-controller="Account" asp-action="Login">Sign In</a>
            }
        </div>
    </nav>

    <nav class="app-sidenav">
        <div class="sidenav-scroll">

            <div class="sidenav-heading">Overview</div>
            <a class="sidenav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Default" ? "active" : "")" asp-controller="Default" asp-action="Index">
                <i class="fas fa-gauge-high"></i><span>Dashboard</span>
            </a>

            <div class="sidenav-heading">IT administration</div>
            <a class="sidenav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "HardwareInventory" ? "active" : "")" asp-controller="HardwareInventory" asp-action="Index">
                <i class="fas fa-server"></i><span>Hardware inventory</span>
            </a>
            <a class="sidenav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "SoftwareLicense" ? "active" : "")" asp-controller="SoftwareLicense" asp-action="Index">
                <i class="fas fa-key"></i><span>Software licenses</span>
            </a>
            <a class="sidenav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "SupportTicket" ? "active" : "")" asp-controller="SupportTicket" asp-action="Index">
                <i class="fas fa-headset"></i><span>Support tickets</span>
            </a>

            <div class="sidenav-heading">Account</div>
            <a class="sidenav-link text-danger-hover" href="javascript:void(0);" onclick="submitLogoutForm();">
                <i class="fas fa-right-from-bracket"></i><span>Logout</span>
            </a>
        </div>

        <div class="sidenav-status">
            <span class="dot"></span>
            <span class="label">All systems operational</span>
        </div>
    </nav>



    <main class="app-content">
        @RenderBody()
    </main>



    <footer class="app-footer">
        <div class="d-flex align-items-center justify-content-between flex-wrap gap-2">
            <span>&copy; @DateTime.Now.Year zaruyashar</span>
            <span>SoftITo Backend Project #5</span>
        </div>
    </footer>


    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery/3.7.1/jquery.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/simple-datatables@7.1.2/dist/umd/simple-datatables.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/2.8.0/Chart.min.js" crossorigin="anonymous"></script>

    <script src="~/techhub-template/assets/js/layout.js"></script>

    @await RenderSectionAsync("Scripts", required: false)

    <form id="logoutForm" class="d-none" asp-controller="Account" asp-action="Logout" method="post">
        @Html.AntiForgeryToken()
    </form>

    <script>
        function submitLogoutForm() {
            if (confirm("Are you sure you want to sign out?")) {
                document.getElementById('logoutForm').submit();
            }
        }
    </script>

</body>
</html>