@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no" />
    <title>Set New Password - TechHub Admin Portal</title>
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="~/techhub-template/assets/css/theme.css" rel="stylesheet" />
    <link href="~/css/additionaldesigncomponents.css" rel="stylesheet" />
</head>
<body class="bg-light">

    <div class="auth-shell">
        <div class="auth-aside">
            <div>
                <a class="app-brand text-decoration-none" href="#">
                    <span class="brand-mark"><i class="fab fa-hive"></i></span>
                    <span class="fs-4 fw-bold text-white ms-2">TECHHUB</span>
                </a>
                <h2>Define a new password.</h2>
                <p>Ensure your account security is up-to-date by configuring a robust administrator credential passphrase.</p>
                
                <div class="auth-stat-row">
                    <div>
                        <div class="figure">100%</div>
                        <div class="caption">System control</div>
                    </div>
                    <div>
                        <div class="figure">0ms</div>
                        <div class="caption">Query latency</div>
                    </div>
                </div>
            </div>
            <div class="auth-foot">
                <span>&copy; @DateTime.Now.Year zaruyashar. SoftITo Backend Project #5.</span>
            </div>
        </div>

        <div class="auth-main">
            <div class="auth-card" id="changeCardContent">
                <div class="auth-eyebrow">ADMIN CONSOLE</div>
                <h1>Choose New Password</h1>
                <p class="auth-subtext">Submit your new admin credentials below.</p>

                <div class="alert alert-danger d-none" id="errorMessage" role="alert"></div>

                <form id="changeForm">
                    <input type="hidden" id="Username" value="@ViewBag.Username" />
                    <input type="hidden" id="Token" value="@ViewBag.Token" />

                    <div class="mb-3">
                        <label class="form-label">New Password</label>
                        <div class="input-group">
                            <span class="input-group-text bg-white border-end-0 text-muted"><i class="fas fa-lock"></i></span>
                            <input type="password" class="form-control border-start-0 ps-0" id="NewPassword" placeholder="Minimum 8 characters" required autocomplete="new-password">
                        </div>
                    </div>
                    <div class="mb-4">
                        <label class="form-label">Confirm New Password</label>
                        <div class="input-group">
                            <span class="input-group-text bg-white border-end-0 text-muted"><i class="fas fa-lock-check"></i></span>
                            <input type="password" class="form-control border-start-0 ps-0" id="ConfirmNewPassword" placeholder="••••••••" required autocomplete="new-password">
                        </div>
                    </div>
                    <div class="d-grid mb-3">
                        <button type="button" class="btn btn-primary btn-lg" onclick="submitChange()">Reset Password</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery/3.7.1/jquery.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        function submitChange() {
            $('#errorMessage').addClass('d-none').html('');
            
            var username = $('#Username').val();
            var token = $('#Token').val();
            var newPassword = $('#NewPassword').val();
            var confirmNewPassword = $('#ConfirmNewPassword').val();

            if (!username || !token) {
                $('#errorMessage').text('Reset token or username is missing. Please restart the forgot password process.').removeClass('d-none');
                return;
            }

            if (!newPassword || !confirmNewPassword) {
                $('#errorMessage').text('Please fill in all fields.').removeClass('d-none');
                return;
            }

            if (newPassword !== confirmNewPassword) {
                $('#errorMessage').text('Passwords do not match.').removeClass('d-none');
                return;
            }

            var changeData = {
                Username: username,
                Token: token,
                NewPassword: newPassword,
                ConfirmNewPassword: confirmNewPassword
            };

            $.ajax({
                url: '@Url.Action("ChangePassword", "Account")',
                type: 'POST',
                data: changeData,
                success: function (response) {
                    if (response.success) {
                        $('#changeCardContent').html(`
                            <div class="text-center py-4">
                                <div class="mb-4 text-success" style="font-size: 4rem;">
                                    <i class="far fa-circle-check"></i>
                                </div>
                                <h3 class="mb-3">Password Reset Complete!</h3>
                                <p class="text-muted mb-4">Your login password has been updated successfully.</p>
                                <div class="d-grid">
                                    <a href="@Url.Action("Login", "Account")" class="btn btn-primary btn-lg">Return to Login</a>
                                </div>
                            </div>
                        `);
                    } else {
                        var errHtml = '<ul>';
                        if (response.errors) {
                            $.each(response.errors, function (i, val) {
                                errHtml += '<li>' + val + '</li>';
                            });
                        } else {
                            errHtml += '<li>An unknown error occurred.</li>';
                        }
                        errHtml += '</ul>';
                        $('#errorMessage').html(errHtml).removeClass('d-none');
                    }
                },
                error: function () {
                    $('#errorMessage').text('An error occurred during password reset.').removeClass('d-none');
                }
            });
        }

        // Support enter key submit
        $(document).ready(function() {
            $('#changeForm input').keypress(function (e) {
                if (e.which == 13) {
                    submitChange();
                    return false;
                }
            });
        });
    </script>
</body>
</html>
