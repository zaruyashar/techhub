@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no" />
    <title>Reset Password - TechHub Admin Portal</title>
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="~/techhub-template/assets/css/theme.css" rel="stylesheet" />
    <link href="~/css/additionaldesigncomponents.css" rel="stylesheet" />
</head>
<body class="bg-light">

    <div class="auth-shell">
        <div class="auth-aside">
            <div>
                <a class="app-brand text-decoration-none" href="#">
                    <span class="brand-mark"><i class="fab fa-hive"></i></span>
                    <span class="fs-4 fw-bold text-white ms-2">TECHHUB</span>
                </a>
                <h2>Forgotten credentials?</h2>
                <p>Verify your administrator identity to generate a system password reset bypass token.</p>
                
                <div class="auth-stat-row">
                    <div>
                        <div class="figure">100%</div>
                        <div class="caption">System control</div>
                    </div>
                    <div>
                        <div class="figure">0ms</div>
                        <div class="caption">Query latency</div>
                    </div>
                </div>
            </div>
            <div class="auth-foot">
                <span>&copy; @DateTime.Now.Year zaruyashar. SoftITo Backend Project #5.</span>
            </div>
        </div>

        <div class="auth-main">
            <div class="auth-card" id="verifyCardContent">
                <div class="auth-eyebrow">ADMIN CONSOLE</div>
                <h1>Forgot Password</h1>
                <p class="auth-subtext">Enter your username or email address below to identify your account.</p>

                <div class="alert alert-danger d-none" id="errorMessage" role="alert"></div>

                <form id="verifyForm">
                    <div class="mb-4">
                        <label class="form-label">Username or Email</label>
                        <div class="input-group">
                            <span class="input-group-text bg-white border-end-0 text-muted"><i class="far fa-user"></i></span>
                            <input type="text" class="form-control border-start-0 ps-0" id="EmailOrUsername" placeholder="e.g. admin@techhub.com" required>
                        </div>
                    </div>
                    <div class="d-grid mb-3">
                        <button type="button" class="btn btn-primary btn-lg" onclick="submitVerify()">Verify Account</button>
                    </div>
                </form>

                <div class="auth-foot-link">
                    Back to <a asp-action="Login" class="text-primary text-decoration-none fw-semibold">Sign In</a>
                </div>
            </div>
        </div>
    </div>

    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery/3.7.1/jquery.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        function submitVerify() {
            $('#errorMessage').addClass('d-none').text('');
            
            var emailOrUsername = $('#EmailOrUsername').val();
            if (!emailOrUsername) {
                $('#errorMessage').text('Please fill in your username or email address.').removeClass('d-none');
                return;
            }

            $.ajax({
                url: '@Url.Action("VerifyEmail", "Account")',
                type: 'POST',
                data: { EmailOrUsername: emailOrUsername },
                success: function (response) {
                    if (response.success) {
                        var changeUrl = '@Url.Action("ChangePassword", "Account")' + '?username=' + encodeURIComponent(response.username) + '&token=' + encodeURIComponent(response.token);
                        
                        $('#verifyCardContent').html(`
                            <div class="text-start">
                                <h1 class="h3 mb-3">Account Verified!</h1>
                                <p class="text-muted small mb-4">A password reset token has been generated. Since no mailer service is configured in this setup, please use the token printed below.</p>
                                
                                <div class="card bg-dark text-white p-3 mb-4 text-mono border-0 shadow-sm" style="word-break: break-all;">
                                    <span class="text-warning small d-block mb-1 fw-bold"><i class="fas fa-bug me-1"></i> DEV RESET TOKEN:</span>
                                    <code class="text-info">${response.token}</code>
                                </div>

                                <div class="d-grid">
                                    <a href="${changeUrl}" class="btn btn-primary btn-lg mb-2">Proceed to Change Password</a>
                                    <a href="@Url.Action("Login")" class="btn btn-outline-secondary">Cancel & Go Back</a>
                                </div>
                            </div>
                        `);
                    } else {
                        $('#errorMessage').text(response.message).removeClass('d-none');
                    }
                },
                error: function () {
                    $('#errorMessage').text('An error occurred during verification.').removeClass('d-none');
                }
            });
        }

        // Support enter key submit
        $(document).ready(function() {
            $('#verifyForm input').keypress(function (e) {
                if (e.which == 13) {
                    submitVerify();
                    return false;
                }
            });
        });
    </script>
</body>
</html>
