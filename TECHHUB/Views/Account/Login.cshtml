@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no" />
    <title>Login - TechHub Admin Portal</title>
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="~/techhub-template/assets/css/theme.css" rel="stylesheet" />
    <link href="~/css/additionaldesigncomponents.css" rel="stylesheet" />
</head>
<body class="bg-light">

    <div class="auth-shell">
        <div class="auth-aside">
            <div>
                <a class="app-brand text-decoration-none" href="#">
                    <span class="brand-mark"><i class="fab fa-hive"></i></span>
                    <span class="fs-4 fw-bold text-white ms-2">TECHHUB</span>
                </a>
                <h2>Simplifying IT asset tracking & support tickets.</h2>
                <p>Secure access to manage hardware inventories, software license seats, and resolve helpdesk support tickets.</p>
                
                <div class="auth-stat-row">
                    <div>
                        <div class="figure">100%</div>
                        <div class="caption">System control</div>
                    </div>
                    <div>
                        <div class="figure">0ms</div>
                        <div class="caption">Query latency</div>
                    </div>
                </div>
            </div>
            <div class="auth-foot">
                <span>&copy; @DateTime.Now.Year zaruyashar. SoftITo Backend Project #5.</span>
            </div>
        </div>

        <div class="auth-main">
            <div class="auth-card" id="loginCardContent">
                <div class="auth-eyebrow">ADMIN CONSOLE</div>
                <h1>Sign in to TechHub</h1>
                <p class="auth-subtext">Enter your credentials to access administration tools.</p>

                <div class="alert alert-danger d-none" id="errorMessage" role="alert"></div>

                <form id="loginForm">
                    <input type="hidden" id="ReturnUrl" value="@ViewBag.ReturnUrl" />
                    <div class="mb-3">
                        <label class="form-label">Email or Username</label>
                        <div class="input-group">
                            <span class="input-group-text bg-white border-end-0 text-muted"><i class="far fa-envelope"></i></span>
                            <input type="text" class="form-control border-start-0 ps-0" id="UsernameOrEmail" placeholder="admin@techhub.com" required autocomplete="username">
                        </div>
                    </div>
                    <div class="mb-3">
                        <div class="d-flex justify-content-between">
                            <label class="form-label">Password</label>
                            <a asp-action="VerifyEmail" class="text-decoration-none small text-primary">Forgot password?</a>
                        </div>
                        <div class="input-group">
                            <span class="input-group-text bg-white border-end-0 text-muted"><i class="fas fa-lock"></i></span>
                            <input type="password" class="form-control border-start-0 ps-0" id="Password" placeholder="••••••••" required autocomplete="current-password">
                        </div>
                    </div>
                    <div class="mb-4 form-check">
                        <input type="checkbox" class="form-check-input" id="RememberMe">
                        <label class="form-check-label text-muted small" for="RememberMe">Remember my login on this device</label>
                    </div>
                    <div class="d-grid mb-3">
                        <button type="button" class="btn btn-primary btn-lg" onclick="submitLogin()">Sign In</button>
                    </div>
                </form>

                <div class="auth-foot-link">
                    Don't have an admin account? <a asp-action="Register" class="text-primary text-decoration-none fw-semibold">Register here</a>
                </div>
            </div>
        </div>
    </div>

    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery/3.7.1/jquery.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        function submitLogin() {
            $('#errorMessage').addClass('d-none').text('');
            
            var loginData = {
                UsernameOrEmail: $('#UsernameOrEmail').val(),
                Password: $('#Password').val(),
                RememberMe: $('#RememberMe').is(':checked'),
                ReturnUrl: $('#ReturnUrl').val()
            };

            if (!loginData.UsernameOrEmail || !loginData.Password) {
                $('#errorMessage').text('Please fill in all required fields.').removeClass('d-none');
                return;
            }

            $.ajax({
                url: '@Url.Action("Login", "Account")',
                type: 'POST',
                data: loginData,
                success: function (response) {
                    if (response.success) {
                        // Open dashboard in new tab
                        window.open(response.redirectUrl, '_blank');
                        // Show confirmation on current tab
                        $('#loginCardContent').html(`
                            <div class="text-center py-4">
                                <div class="mb-4 text-success" style="font-size: 4rem;">
                                    <i class="far fa-circle-check"></i>
                                </div>
                                <h3 class="mb-3">Welcome back!</h3>
                                <p class="text-muted mb-4">The admin console has been opened in a new tab.</p>
                                <div class="d-grid gap-2">
                                    <a href="${response.redirectUrl}" target="_blank" class="btn btn-primary">Go to Dashboard</a>
                                    <button class="btn btn-outline-secondary" onclick="window.location.reload();">Log in as another user</button>
                                </div>
                            </div>
                        `);
                    } else {
                        $('#errorMessage').text(response.message).removeClass('d-none');
                    }
                },
                error: function () {
                    $('#errorMessage').text('An error occurred while signing in. Please try again.').removeClass('d-none');
                }
            });
        }

        // Support enter key submit
        $(document).ready(function() {
            $('#loginForm input').keypress(function (e) {
                if (e.which == 13) {
                    submitLogin();
                    return false;
                }
            });
        });
    </script>
</body>
</html>
