@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no" />
    <title>Register - TechHub Admin Portal</title>
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="~/techhub-template/assets/css/theme.css" rel="stylesheet" />
    <link href="~/css/additionaldesigncomponents.css" rel="stylesheet" />
</head>
<body class="bg-light">

    <div class="auth-shell">
        <div class="auth-aside">
            <div>
                <a class="app-brand text-decoration-none" href="#">
                    <span class="brand-mark"><i class="fab fa-hive"></i></span>
                    <span class="fs-4 fw-bold text-white ms-2">TECHHUB</span>
                </a>
                <h2>Create your admin dashboard workspace.</h2>
                <p>Register a single-tier administrator account to log tickets and track licenses in real-time.</p>
                
                <div class="auth-stat-row">
                    <div>
                        <div class="figure">100%</div>
                        <div class="caption">System control</div>
                    </div>
                    <div>
                        <div class="figure">0ms</div>
                        <div class="caption">Query latency</div>
                    </div>
                </div>
            </div>
            <div class="auth-foot">
                <span>&copy; @DateTime.Now.Year zaruyashar. SoftITo Backend Project #5.</span>
            </div>
        </div>

        <div class="auth-main">
            <div class="auth-card" id="registerCardContent">
                <div class="auth-eyebrow">ADMIN CONSOLE</div>
                <h1>Register Admin Account</h1>
                <p class="auth-subtext">Set up your profile to manage system resources.</p>

                <div class="alert alert-danger d-none" id="errorMessage" role="alert"></div>

                <form id="registerForm">
                    <div class="mb-3">
                        <label class="form-label">Full Name</label>
                        <div class="input-group">
                            <span class="input-group-text bg-white border-end-0 text-muted"><i class="far fa-user"></i></span>
                            <input type="text" class="form-control border-start-0 ps-0" id="FullName" placeholder="System Administrator" required>
                        </div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Email Address</label>
                        <div class="input-group">
                            <span class="input-group-text bg-white border-end-0 text-muted"><i class="far fa-envelope"></i></span>
                            <input type="email" class="form-control border-start-0 ps-0" id="Email" placeholder="admin@techhub.com" required autocomplete="email">
                        </div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Password</label>
                        <div class="input-group">
                            <span class="input-group-text bg-white border-end-0 text-muted"><i class="fas fa-lock"></i></span>
                            <input type="password" class="form-control border-start-0 ps-0" id="Password" placeholder="Minimum 8 characters" required autocomplete="new-password">
                        </div>
                    </div>
                    <div class="mb-4">
                        <label class="form-label">Confirm Password</label>
                        <div class="input-group">
                            <span class="input-group-text bg-white border-end-0 text-muted"><i class="fas fa-lock-check"></i></span>
                            <input type="password" class="form-control border-start-0 ps-0" id="ConfirmPassword" placeholder="••••••••" required autocomplete="new-password">
                        </div>
                    </div>
                    <div class="d-grid mb-3">
                        <button type="button" class="btn btn-primary btn-lg" onclick="submitRegister()">Create Account</button>
                    </div>
                </form>

                <div class="auth-foot-link">
                    Already registered? <a asp-action="Login" class="text-primary text-decoration-none fw-semibold">Sign in here</a>
                </div>
            </div>
        </div>
    </div>

    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery/3.7.1/jquery.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        function submitRegister() {
            $('#errorMessage').addClass('d-none').html('');
            
            var fullName = $('#FullName').val();
            var email = $('#Email').val();
            var password = $('#Password').val();
            var confirmPassword = $('#ConfirmPassword').val();

            if (!fullName || !email || !password || !confirmPassword) {
                $('#errorMessage').text('Please fill in all fields.').removeClass('d-none');
                return;
            }

            if (password !== confirmPassword) {
                $('#errorMessage').text('Passwords do not match.').removeClass('d-none');
                return;
            }

            var registerData = {
                FullName: fullName,
                Email: email,
                Password: password,
                ConfirmPassword: confirmPassword
            };

            $.ajax({
                url: '@Url.Action("Register", "Account")',
                type: 'POST',
                data: registerData,
                success: function (response) {
                    if (response.success) {
                        var redirectUrl = '@Url.Action("Index", "Default")';
                        // Open dashboard in new tab
                        window.open(redirectUrl, '_blank');
                        // Show success message
                        $('#registerCardContent').html(`
                            <div class="text-center py-4">
                                <div class="mb-4 text-success" style="font-size: 4rem;">
                                    <i class="far fa-circle-check"></i>
                                </div>
                                <h3 class="mb-3">Account Registered!</h3>
                                <p class="text-muted mb-4">Your administrative workspace has been created and opened in a new tab.</p>
                                <div class="d-grid gap-2">
                                    <a href="${redirectUrl}" target="_blank" class="btn btn-primary">Go to Dashboard</a>
                                </div>
                            </div>
                        `);
                    } else {
                        var errHtml = '<ul>';
                        if (response.errors) {
                            $.each(response.errors, function (i, val) {
                                errHtml += '<li>' + val + '</li>';
                            });
                        } else {
                            errHtml += '<li>An unknown error occurred.</li>';
                        }
                        errHtml += '</ul>';
                        $('#errorMessage').html(errHtml).removeClass('d-none');
                    }
                },
                error: function () {
                    $('#errorMessage').text('An error occurred during registration. Please check inputs and try again.').removeClass('d-none');
                }
            });
        }

        // Support enter key submit
        $(document).ready(function() {
            $('#registerForm input').keypress(function (e) {
                if (e.which == 13) {
                    submitRegister();
                    return false;
                }
            });
        });
    </script>
</body>
</html>
