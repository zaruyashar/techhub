@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Access Denied";
}

<div class="container-fluid px-4 mt-5 text-center">
    <div class="py-5">
        <div class="text-danger mb-4 animate__animated animate__shakeX" style="font-size: 5rem;">
            <i class="fas fa-shield-halved"></i>
        </div>
        <h1 class="page-title fs-2 text-slate-900 mb-2">Access Denied</h1>
        <p class="page-subtitle text-slate-500 mb-4">You do not have the required permissions to access this administrative component.</p>
        <div class="d-flex justify-content-center gap-2">
            <a href="@Url.Action("Index", "Default")" class="btn btn-primary px-4"><i class="fas fa-arrow-left me-1"></i> Back to Dashboard</a>
        </div>
    </div>
</div>
