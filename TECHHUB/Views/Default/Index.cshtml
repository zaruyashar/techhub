@{
    ViewData["Title"] = "Index";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    .dashboard-stat-card {
        padding: 2.5rem !important;
        transition: all 0.3s cubic-bezier(0.25, 0.8, 0.25, 1);
        height: 100%;
        border-radius: 12px;
    }

        .dashboard-stat-card:hover {
            transform: translateY(-8px) scale(1.02);
            box-shadow: 0 1.5rem 3rem rgba(0,0,0,.15) !important;
            cursor: default;
        }

        .dashboard-stat-card .stat-label {
            font-size: 1.1rem;
            margin-bottom: 0.5rem;
        }

        .dashboard-stat-card .stat-value {
            font-size: 3rem;
            font-weight: 700;
        }

        .dashboard-stat-card .stat-icon {
            transform: scale(1.3);
            transform-origin: center right;
        }
</style>


<div class="container-fluid px-4">
    <div class="d-flex justify-content-between align-items-center mt-4 mb-4">
        <div>
            <h1 class="mt-0">Dashboard</h1>
            <ol class="breadcrumb mb-0">
                <li class="breadcrumb-item active">Below you can find your asset management & helpdesk statistics.</li>
            </ol>
        </div>
    </div>
</div>


<div class="row g-4 mb-5 px-4">
    <div class="col-md-6">
        <div class="stat-card dashboard-stat-card shadow-sm">
            <div>
                <div class="stat-label">Open tickets</div>
                <div class="stat-value" id="openTicketsCount">-</div>
            </div>
            <div class="stat-icon icon-cyan"><i class="fas fa-headset"></i></div>
        </div>
    </div>

    <div class="col-md-6">
        <div class="stat-card dashboard-stat-card shadow-sm">
            <div>
                <div class="stat-label">Critical &amp; high urgency</div>
                <div class="stat-value" id="urgentCriticalCount">-</div>
            </div>
            <div class="stat-icon icon-orange"><i class="fas fa-triangle-exclamation"></i></div>
        </div>
    </div>

    <div class="col-md-6">
        <div class="stat-card dashboard-stat-card shadow-sm">
            <div>
                <div class="stat-label">Hardware tracked</div>
                <div class="stat-value" id="hardwareTrackedCount">-</div>
            </div>
            <div class="stat-icon icon-navy"><i class="fas fa-server"></i></div>
        </div>
    </div>

    <div class="col-md-6">
        <div class="stat-card dashboard-stat-card shadow-sm">
            <div>
                <div class="stat-label">Expiring &lt; 30 days</div>
                <div class="stat-value" id="licensesExpiringCount">-</div>
            </div>
            <div class="stat-icon icon-amber"><i class="fas fa-key"></i></div>
        </div>
    </div>
</div>


@section Scripts {
    <script>
        $(document).ready(function () {
            LoadStats();
        });

        function LoadStats() {
            $.ajax({
                url: '@Url.Action("GetDashboardStats", "Default")',
                type: 'GET',
                dataType: 'json',
                success: function (data) {
                    $('#openTicketsCount').text(data.openTickets);
                    $('#urgentCriticalCount').text(data.urgentCriticalTickets);
                    $('#hardwareTrackedCount').text(data.hardwareTracked);
                    $('#licensesExpiringCount').text(data.licensesExpiring);
                }
            });
        }
    </script>
}